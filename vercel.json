{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "clima-hoy.com"
        }
      ],
      "destination": "https://www.clima-hoy.com",
      "permanent": true
    },
    {
      "source": "/((?!api/).*)",
      "has": [
        {
          "type": "host",
          "value": "clima-hoy.com"
        }
      ],
      "destination": "https://www.clima-hoy.com/$1",
      "permanent": true
    }
  ]
}
